{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "width": "container",
  "height": 400,

  "padding": { "left": 12, "top": 6, "right": 12, "bottom": 8 },

  "autosize": {
    "type": "pad",
    "contains": "padding",
    "resize": false
  },

  "title": {
    "text": "3. State Population Over Time (2014–2025)",
    "fontSize": 16,
    "fontWeight": "bold",
    "anchor": "start",
    "offset": 40,
    "lineBreak": " ",
    "limit": 260
  },

  "data": {
    "url": "data/ab.csv",
    "format": { "type": "csv" }
  },

  "transform": [
    {
      "filter": "indexof(['New South Wales','Victoria','Queensland','Western Australia','South Australia'], datum.State) >= 0"
    },
    {
      "filter": "indexof(['2014-Q1','2016-Q1','2018-Q1','2020-Q1','2022-Q1','2024-Q1','2025-Q1'], datum.Quarter) >= 0"
    },
    { "calculate": "toNumber(datum.TotalPopulation)", "as": "Population" },
    {
      "calculate": "datum.State == 'New South Wales' ? 'NSW' : datum.State == 'Victoria' ? 'VIC' : datum.State == 'Queensland' ? 'QLD' : datum.State == 'Western Australia' ? 'WA' : 'SA'",
      "as": "StateAbbr"
    },
    { "calculate": "substring(datum.Quarter, 0, 4)", "as": "Year" }
  ],

  "layer": [
    {
      "mark": {
        "type": "line",
        "point": { "filled": true, "size": 60 },
        "strokeWidth": 2.5
      },
      "encoding": {
        "x": {
          "field": "Year",
          "type": "ordinal",
          "title": null,
          "scale": {
            "domain": ["2014", "2016", "2018", "2020", "2022", "2024", "2025"],
            "paddingInner": 0,
            "paddingOuter": 0
          },
          "axis": {
            "labelFontSize": 13,
            "labelColor": "#333333",
            "labelAngle": 0
          }
        },
        "y": {
          "field": "Population",
          "type": "quantitative",
          "title": "Population",
          "scale": { "domain": [0, 10000000] },
          "axis": {
            "format": "~s",
            "labelFontSize": 13,
            "labelColor": "#333333",
            "titleFontSize": 15,
            "titleFontWeight": 600,
            "titleColor": "#1a1a1a",
            "tickCount": 6
          }
        },
        "color": {
          "field": "StateAbbr",
          "type": "nominal",
          "title": null,
          "scale": {
            "domain": ["NSW", "VIC", "QLD", "WA", "SA"],
            "range": ["#0B2545", "#0F766E", "#2563EB", "#C2410C", "#6D5A7A"]
          },
          "legend": {
            "orient": "top",
            "direction": "horizontal",
            "offset": 4,
            "labelFontSize": 13,
            "labelOffset": 6,
            "columnPadding": 22,
            "symbolSize": 90,
            "symbolStrokeWidth": 2
          }
        },
        "opacity": {
          "condition": {
            "test": "datum.StateAbbr === 'NSW'",
            "value": 1
          },
          "value": 0.38
        },
        "strokeWidth": {
          "condition": {
            "test": "datum.StateAbbr === 'NSW'",
            "value": 3
          },
          "value": 1.75
        },
        "tooltip": [
          { "field": "State", "title": "State" },
          { "field": "Year", "title": "Year" },
          { "field": "Population", "title": "Population", "format": ",.0f" }
        ]
      }
    },
    {
      "transform": [
        { "filter": "datum.StateAbbr === 'NSW' && datum.Year === '2025'" }
      ],
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "bottom",
        "dx": 8,
        "dy": -8,
        "fontSize": 10,
        "font": "Georgia, serif",
        "color": "#333333"
      },
      "encoding": {
        "x": { "field": "Year", "type": "ordinal" },
        "y": { "field": "Population", "type": "quantitative" },
        "text": { "value": "Still largest — 8.6M" }
      }
    }
  ],

  "config": {
    "mark": {
      "point": { "size": 60 }
    }
  }
}
