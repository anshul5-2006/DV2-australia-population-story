{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "width": "container",
  "height": 400,

  "padding": { "left": 56, "top": 6, "right": 12, "bottom": 8 },

  "autosize": {
    "type": "pad",
    "contains": "padding",
    "resize": false
  },

  "title": {
    "text": "4. Components of Population Change (Australia, 2014–2025)",
    "fontSize": 16,
    "fontWeight": "bold",
    "anchor": "start",
    "offset": 40,
    "lineBreak": " ",
    "limit": 260
  },

  "data": {
    "url": "data/ab.csv",
    "format": { "type": "csv" }
  },

  "transform": [
    {
      "filter": "indexof(['2014-Q1','2016-Q1','2018-Q1','2020-Q1','2022-Q1','2024-Q1','2025-Q1'], datum.Quarter) >= 0"
    },
    {
      "fold": [
        "NaturalIncrease",
        "NetOverseasMigration",
        "NetInterstateMigration"
      ],
      "as": ["Component", "Value"]
    },
    { "calculate": "toNumber(datum.Value)", "as": "Value" },
    {
      "calculate": "datum.Component == 'NetInterstateMigration' ? abs(datum.Value) : datum.Value",
      "as": "Value"
    },
    {
      "calculate": "datum.Component == 'NaturalIncrease' ? 'Natural increase' : datum.Component == 'NetOverseasMigration' ? 'Net overseas migration' : 'Net interstate migration'",
      "as": "ComponentLabel"
    },
    {
      "aggregate": [{ "op": "sum", "field": "Value", "as": "Total" }],
      "groupby": ["Quarter", "ComponentLabel"]
    },
    { "calculate": "substring(datum.Quarter, 0, 4)", "as": "Year" }
  ],

  "layer": [
    {
      "mark": {
        "type": "area",
        "line": { "strokeWidth": 1.5, "color": "#ffffff" },
        "interpolate": "monotone"
      },
      "encoding": {
        "x": {
          "field": "Year",
          "type": "ordinal",
          "title": null,
          "scale": {
            "domain": ["2014", "2016", "2018", "2020", "2022", "2024", "2025"],
            "paddingInner": 0,
            "paddingOuter": 0
          },
          "axis": {
            "labelFontSize": 13,
            "labelColor": "#333333"
          }
        },
        "y": {
          "field": "Total",
          "type": "quantitative",
          "title": "Population change",
          "stack": "zero",
          "axis": {
            "format": "~s",
            "labelFontSize": 13,
            "labelColor": "#333333",
            "titleFontSize": 15,
            "titleFontWeight": 600,
            "titleColor": "#1a1a1a",
            "tickCount": 5
          }
        },
        "color": {
          "field": "ComponentLabel",
          "type": "nominal",
          "title": null,
          "scale": {
            "domain": [
              "Natural increase",
              "Net overseas migration",
              "Net interstate migration"
            ],
            "range": ["#EDBE87", "#15803D", "#A7ADB7"]
          },
          "legend": {
            "orient": "top",
            "direction": "horizontal",
            "offset": 4,
            "labelFontSize": 13,
            "labelOffset": 6,
            "columnPadding": 22,
            "symbolSize": 100,
            "columns": 3
          }
        },
        "order": {
          "field": "ComponentLabel",
          "sort": [
            "Natural increase",
            "Net overseas migration",
            "Net interstate migration"
          ]
        },
        "tooltip": [
          { "field": "Year", "title": "Year" },
          { "field": "ComponentLabel", "title": "Component" },
          { "field": "Total", "title": "Total", "format": ",.0f" }
        ]
      }
    },
    {
      "data": {
        "values": [
          { "Year": "2020", "Year2": "2022", "y": 147000, "y2": 123000 }
        ]
      },
      "mark": {
        "type": "rule",
        "color": "#1a1a1a",
        "strokeWidth": 1,
        "strokeCap": "round"
      },
      "encoding": {
        "x": {
          "field": "Year",
          "type": "ordinal",
          "scale": {
            "domain": ["2014", "2016", "2018", "2020", "2022", "2024", "2025"]
          }
        },
        "x2": { "field": "Year2" },
        "y": { "field": "y", "type": "quantitative" },
        "y2": { "field": "y2" }
      }
    },
    {
      "data": {
        "values": [
          {
            "Year": "2020",
            "y": 150000,
            "text": ["Migration rebounds", "after border reopening"]
          }
        ]
      },
      "mark": {
        "type": "text",
        "align": "right",
        "baseline": "bottom",
        "lineHeight": 14,
        "dy": -4,
        "dx": -2,
        "font": "Georgia, serif",
        "color": "#1a1a1a"
      },
      "encoding": {
        "x": {
          "field": "Year",
          "type": "ordinal",
          "scale": {
            "domain": ["2014", "2016", "2018", "2020", "2022", "2024", "2025"]
          }
        },
        "y": { "field": "y", "type": "quantitative" },
        "text": { "field": "text" }
      }
    }
  ]
}
