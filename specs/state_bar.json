{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "width": "container",
  "height": 400,

  "padding": { "left": 8, "top": 24, "right": 52, "bottom": 26 },

  "autosize": {
    "type": "fit",
    "contains": "padding",
    "resize": false
  },

  "title": {
    "text": "2. Largest States by Population (Latest)",
    "fontSize": 16,
    "fontWeight": "bold",
    "anchor": "start",
    "offset": 22,
    "lineBreak": " ",
    "limit": 260
  },

  "data": {
    "url": "data/ab.csv",
    "format": { "type": "csv" }
  },

  "transform": [
    { "filter": "datum.Quarter == '2025-Q3'" },
    { "calculate": "toNumber(datum.TotalPopulation)", "as": "Population" }
  ],

  "mark": {
    "type": "bar",
    "cornerRadiusEnd": 3,
    "color": "#2b6cb0"
  },

  "encoding": {
    "y": {
      "field": "State",
      "type": "nominal",
      "title": null,
      "sort": "-x",
      "scale": { "paddingInner": 0.15, "paddingOuter": 0.06 },
      "axis": {
        "labelFontSize": 13,
        "labelFontWeight": 600,
        "labelColor": "#2a2a2a",
        "labelLimit": 150
      }
    },
    "x": {
      "field": "Population",
      "type": "quantitative",
      "title": "Population",
      "scale": { "nice": true, "zero": true, "padding": 0.06 },
      "axis": {
        "format": "~s",
        "labelFontSize": 13,
        "labelFontWeight": 600,
        "labelColor": "#333333",
        "titleColor": "#1f1f1f",
        "titleFontSize": 13,
        "titleFontWeight": 600,
        "tickColor": "#888888",
        "tickCount": 6,
        "labelPadding": 6,
        "titlePadding": 12
      }
    },
    "tooltip": [
      { "field": "State", "title": "State" },
      { "field": "Population", "title": "Population", "format": ",.0f" }
    ]
  }
}
