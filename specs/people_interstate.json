{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "width": "container",
  "height": 380,

  "padding": { "left": 56, "top": 38, "right": 56, "bottom": 10 },

  "autosize": {
    "type": "fit",
    "contains": "padding",
    "resize": false
  },

  "title": {
    "text": "10. Interstate Migration — Winners & Losers (2024–25)",
    "fontSize": 16,
    "fontWeight": "bold",
    "anchor": "start",
    "offset": 8,
    "lineBreak": " ",
    "limit": 320
  },

  "data": {
    "url": "data/ab.csv",
    "format": { "type": "csv" }
  },

  "transform": [
    {
      "filter": "indexof(['Queensland','Western Australia','South Australia','New South Wales','Victoria','Australian Capital Territory'], datum.State) >= 0"
    },
    {
      "filter": "indexof(['2024-Q3','2024-Q4','2025-Q1','2025-Q2','2025-Q3'], datum.Quarter) >= 0"
    },
    { "calculate": "toNumber(datum.NetInterstateMigration)", "as": "Migration" },
    {
      "aggregate": [{ "op": "sum", "field": "Migration", "as": "Migration" }],
      "groupby": ["State"]
    },
    {
      "calculate": "datum.State == 'Australian Capital Territory' ? 'ACT' : datum.State == 'New South Wales' ? 'NSW' : datum.State == 'South Australia' ? 'SA' : datum.State == 'Victoria' ? 'VIC' : datum.State == 'Western Australia' ? 'WA' : datum.State == 'Queensland' ? 'QLD' : datum.State",
      "as": "StateShort"
    },
    {
      "calculate": "datum.Migration >= 0 ? 'gain' : 'loss'",
      "as": "Direction"
    },
    { "calculate": "abs(datum.Migration)", "as": "AbsMigration" },
    {
      "window": [{ "op": "rank", "as": "Rank" }],
      "sort": [{ "field": "AbsMigration", "order": "descending" }]
    }
  ],

  "encoding": {
    "y": {
      "field": "StateShort",
      "type": "nominal",
      "title": null,
      "sort": { "field": "Rank", "order": "ascending" },
      "scale": {
        "paddingInner": 0.2,
        "paddingOuter": 0.12
      },
      "axis": {
        "labelFontSize": 12,
        "labelFontWeight": 600,
        "labelColor": "#2a2a2a",
        "labelPadding": 8,
        "offset": 4,
        "labelAlign": "right",
        "labelBound": true,
        "ticks": false
      }
    },
    "x": {
      "field": "Migration",
      "type": "quantitative",
      "title": "Net interstate migration",
      "scale": {
        "domain": [-35000, 35000],
        "nice": false,
        "zero": true
      },
      "axis": {
        "labelExpr": "format(datum.value/1000, '.0f') + 'K'",
        "labelFontSize": 12,
        "labelFontWeight": 600,
        "labelColor": "#333333",
        "titleFontSize": 13,
        "titleFontWeight": 600,
        "titleColor": "#1a1a1a",
        "values": [-30000, -20000, -10000, 0, 10000, 20000],
        "grid": {
          "condition": { "test": "datum.value === 0", "value": false },
          "value": true
        },
        "gridOpacity": 0.1,
        "gridColor": "#d8d8d8"
      }
    },
    "color": {
      "field": "Direction",
      "type": "nominal",
      "legend": null,
      "scale": {
        "domain": ["gain", "loss"],
        "range": ["#23563a", "#822a2a"]
      }
    },
    "tooltip": [
      { "field": "State", "title": "State" },
      { "field": "Migration", "title": "Migration", "format": "+,.0f" }
    ]
  },

  "layer": [
    {
      "mark": { "type": "bar", "size": 12 },
      "encoding": {
        "x2": { "value": 0 },
        "opacity": {
          "condition": {
            "test": "datum.StateShort === 'QLD' || datum.StateShort === 'NSW'",
            "value": 1
          },
          "value": 0.78
        },
        "color": {
          "field": "Direction",
          "type": "nominal",
          "scale": {
            "domain": ["gain", "loss"],
            "range": ["#23563a", "#822a2a"]
          }
        }
      }
    },
    {
      "transform": [{ "filter": "datum.StateShort === 'QLD'" }],
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "middle",
        "dx": 8,
        "fontSize": 10,
        "font": "Georgia, serif",
        "color": "#333333"
      },
      "encoding": {
        "y": {
          "field": "StateShort",
          "type": "nominal",
          "sort": { "field": "Rank", "order": "ascending" }
        },
        "x": { "field": "Migration", "type": "quantitative" },
        "text": { "value": "Strongest net gain (+25K)" }
      }
    },
    {
      "transform": [
        {
          "window": [
            {
              "op": "rank",
              "as": "yOrder",
              "sort": [{ "field": "Rank", "order": "ascending" }]
            }
          ]
        },
        {
          "joinaggregate": [
            { "op": "min", "field": "yOrder", "as": "yMin" },
            { "op": "max", "field": "yOrder", "as": "yMax" }
          ]
        },
        {
          "filter": "datum.yOrder == datum.yMin || datum.yOrder == datum.yMax"
        }
      ],
      "mark": {
        "type": "line",
        "stroke": "#000000",
        "strokeWidth": 3,
        "opacity": 1
      },
      "encoding": {
        "x": { "datum": 0, "type": "quantitative" },
        "y": {
          "field": "StateShort",
          "type": "nominal",
          "sort": { "field": "Rank", "order": "ascending" }
        },
        "order": { "field": "yOrder" }
      }
    }
  ],

  "config": {
    "view": { "stroke": null },
    "axis": {
      "labelColor": "#333333",
      "titleColor": "#333333",
      "grid": true,
      "gridOpacity": 0.15
    }
  }
}
