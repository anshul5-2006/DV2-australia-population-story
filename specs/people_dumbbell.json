{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "width": "container",
  "height": 380,

  "padding": { "left": 22, "top": 48, "right": 36, "bottom": 10 },

  "autosize": {
    "type": "fit",
    "contains": "padding",
    "resize": false
  },

  "title": {
    "text": "9. Are Capital Cities Growing Faster Than Regional Areas? (2014 vs 2025)",
    "fontSize": 16,
    "fontWeight": "bold",
    "anchor": "start",
    "offset": 8,
    "lineBreak": " ",
    "limit": 320
  },

  "data": {
    "url": "data/regional_population.csv",
    "format": { "type": "csv" }
  },

  "transform": [
    { "calculate": "toNumber(datum.Pop2014)", "as": "Pop2014" },
    { "calculate": "toNumber(datum.Pop2025)", "as": "Pop2025" },
    {
      "calculate": "datum.Region == 'Greater Sydney' ? 'Sydney' : datum.Region == 'Rest of NSW' ? 'Regional NSW' : datum.Region == 'Greater Melbourne' ? 'Melbourne' : datum.Region == 'Rest of Victoria' ? 'Regional VIC' : datum.Region",
      "as": "RegionLabel"
    }
  ],

  "encoding": {
    "y": {
      "field": "RegionLabel",
      "type": "nominal",
      "title": null,
      "scale": {
        "domain": ["Sydney", "Regional NSW", "Melbourne", "Regional VIC"],
        "paddingInner": 0.15,
        "paddingOuter": 0.08
      },
      "axis": {
        "labelFontSize": 13,
        "labelFontWeight": 600,
        "labelColor": "#2a2a2a",
        "labelPadding": 8
      }
    }
  },

  "layer": [
    {
      "mark": { "type": "rule", "color": "#5f5f5f", "strokeWidth": 1.25 },
      "encoding": {
        "y": { "field": "RegionLabel", "type": "nominal" },
        "x": {
          "field": "Pop2014",
          "type": "quantitative",
          "scale": {
            "domain": [1320000, 5480000],
            "nice": false,
            "padding": 0.1
          }
        },
        "x2": { "field": "Pop2025", "type": "quantitative" }
      }
    },
    {
      "transform": [
        { "fold": ["Pop2014", "Pop2025"], "as": ["YearKey", "Population"] },
        {
          "calculate": "datum.YearKey == 'Pop2014' ? '2014' : '2025'",
          "as": "Year"
        },
        { "calculate": "toNumber(datum.Population)", "as": "Population" }
      ],
      "mark": {
        "type": "point",
        "stroke": "#2b6cb0",
        "strokeWidth": 1.5,
        "size": 100,
        "filled": {
          "condition": { "test": "datum.Year == '2025'", "value": true },
          "value": false
        }
      },
      "encoding": {
        "y": { "field": "RegionLabel", "type": "nominal" },
        "x": {
          "field": "Population",
          "type": "quantitative",
          "title": "Population (millions)",
          "scale": {
            "domain": [1320000, 5480000],
            "nice": false,
            "padding": 0.1
          },
          "axis": {
            "labelExpr": "datum.value >= 1e6 ? format(datum.value/1e6, '.0f') + 'M' : format(datum.value/1e3, '.0f') + 'k'",
            "labelFontSize": 12,
            "labelFontWeight": 600,
            "labelColor": "#333333",
            "titleFontSize": 13,
            "titleFontWeight": 600,
            "titleColor": "#1a1a1a",
            "titlePadding": 10,
            "tickCount": 5
          }
        },
        "color": {
          "field": "Year",
          "type": "nominal",
          "legend": {
            "orient": "top",
            "direction": "horizontal",
            "title": null,
            "labelFontSize": 12,
            "symbolSize": 64,
            "symbolStrokeWidth": 1.5,
            "offset": 6,
            "padding": 12,
            "labelOffset": 6,
            "columnPadding": 20
          },
          "scale": {
            "domain": ["2014", "2025"],
            "range": ["#fafafa", "#2b6cb0"]
          }
        },
        "tooltip": [
          { "field": "Region", "title": "Region" },
          { "field": "Year", "title": "Year" },
          { "field": "Population", "title": "Population", "format": ",.0f" }
        ]
      }
    }
  ],

  "resolve": {
    "scale": { "x": "shared", "y": "shared" }
  },

  "config": {
    "view": { "stroke": null },
    "axis": {
      "labelColor": "#333333",
      "titleColor": "#333333",
      "grid": true,
      "gridOpacity": 0.15
    },
    "legend": {
      "orient": "top",
      "direction": "horizontal",
      "offset": 4,
      "padding": 10,
      "labelOffset": 4
    }
  }
}
